# ce fichier est un exemple de fichier d'environnement. Copiez-le et renommez-le en .env.local, puis remplissez les valeurs appropriées pour votre configuration locale. Ne commettez jamais vos fichiers d'environnement réels dans le contrôle de version, car ils peuvent contenir des informations sensibles.

# Base de données
DATABASE_URL=

# Auth
JWT_SECRET=
JWT_REFRESH_SECRET=

# Chiffrement — clé AES-256 (32 octets)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Résultat : 64 caractères hex → à lire avec Buffer.from(key, 'hex') dans le code
ENCRYPTION_KEY=

# Email
RESEND_API_KEY=
EMAIL_FROM=Quineo <commandes@quineo.fr>

# App
# IMPORTANT : utilisé pour les URLs de retour paiement (ex: https://votreapp.com)
NEXT_PUBLIC_APP_URL=
NODE_ENV=

# Token de consultation des données de paiement — protège les PII sur l'endpoint public
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_VIEW_SECRET=

# Paiements — Les credentials ET secrets webhook sont configurés par association dans Paramètres → Paiements.
# Les URLs de webhook à renseigner dans chaque dashboard fournisseur :
#   Stripe     : https://votreapp.com/api/webhooks/stripe
#   PayPal     : https://votreapp.com/api/webhooks/paypal?token=<webhook_token de l'association>
#   SumUp      : https://votreapp.com/api/webhooks/sumup    (secret HMAC configuré dans SumUp)
#   HelloAsso  : https://votreapp.com/api/webhooks/helloasso (+ Authorization: Bearer <webhook_secret>)