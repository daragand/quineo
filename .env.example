# ce fichier est un exemple de fichier d'environnement. Copiez-le et renommez-le en .env.local, puis remplissez les valeurs appropriées pour votre configuration locale. Ne commettez jamais vos fichiers d'environnement réels dans le contrôle de version, car ils peuvent contenir des informations sensibles.

# Base de données
DATABASE_URL=

# Auth
JWT_SECRET=
JWT_REFRESH_SECRET=

# Chiffrement — clé AES-256 (32 octets)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Résultat : 64 caractères hex → à lire avec Buffer.from(key, 'hex') dans le code
ENCRYPTION_KEY=

# Email
RESEND_API_KEY=
EMAIL_FROM=Quineo <commandes@quineo.fr>

# App
# IMPORTANT : utilisé pour les URLs de retour paiement (ex: https://votreapp.com)
NEXT_PUBLIC_APP_URL=
NODE_ENV=

# Token de consultation des données de paiement — protège les PII sur l'endpoint public
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_VIEW_SECRET=

# Paiements — Les credentials sont configurés par association dans l'interface Paramètres → Paiements.
# Les URLs de webhook à configurer dans chaque dashboard fournisseur :
#   Stripe     : https://votreapp.com/api/webhooks/stripe
#   PayPal     : https://votreapp.com/api/webhooks/paypal   (configurer Authorization: Bearer <PAYPAL_WEBHOOK_SECRET>)
#   SumUp      : https://votreapp.com/api/webhooks/sumup    (signature HMAC automatique)
#   HelloAsso  : https://votreapp.com/api/webhooks/helloasso (configurer Authorization: Bearer <HELLOASSO_WEBHOOK_SECRET>)

# Secrets webhook — à définir puis configurer dans chaque dashboard fournisseur
# Générer chaque secret : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HELLOASSO_WEBHOOK_SECRET=
PAYPAL_WEBHOOK_SECRET=
SUMUP_WEBHOOK_SECRET=