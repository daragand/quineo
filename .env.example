# ce fichier est un exemple de fichier d'environnement. Copiez-le et renommez-le en .env.local, puis remplissez les valeurs appropriées pour votre configuration locale. Ne commettez jamais vos fichiers d'environnement réels dans le contrôle de version, car ils peuvent contenir des informations sensibles.

# Base de données
DATABASE_URL=

# Auth
JWT_SECRET=
JWT_REFRESH_SECRET=

# Chiffrement
ENCRYPTION_KEY=

# Email
RESEND_API_KEY=

# App
# IMPORTANT : utilisé pour les URLs de retour paiement (ex: https://votreapp.com)
NEXT_PUBLIC_APP_URL=
NODE_ENV=

# Paiements — Les credentials sont configurés par association dans l'interface Paramètres → Paiements.
# Les URLs de webhook à configurer dans chaque dashboard fournisseur :
#   Stripe     : https://votreapp.com/api/webhooks/stripe
#   PayPal     : https://votreapp.com/api/webhooks/paypal
#   SumUp      : https://votreapp.com/api/webhooks/sumup
#   HelloAsso  : https://votreapp.com/api/webhooks/helloasso